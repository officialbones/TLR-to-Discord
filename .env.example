# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Transcription API (Whisper-compatible)
# This is your Whisper endpoint for audio-to-text
TRANSCRIPTION_URL=https://YOUR_WHISPER_URL/v1/audio/transcriptions

# LLM API for AI-powered summarization
# Requires an Ollama instance running with a model pulled.
# Recommended: ollama pull llama3.2:3b
# Then expose Ollama via Cloudflare tunnel or direct URL.
# Ollama serves an OpenAI-compatible API at /v1/chat/completions
LLM_URL=https://YOUR_OLLAMA_URL/v1/chat/completions
LLM_MODEL=llama3.2:3b

# Polling interval in seconds
POLL_INTERVAL=60

# State file path (tracks last processed alert)
STATE_FILE=./state.json
